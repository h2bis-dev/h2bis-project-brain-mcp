# H2BIS MCP — Runtime Configuration
# -----------------------------------------------------------------
# This file is for LOCAL DEVELOPMENT only.
# When published as an npm package, users configure via mcp.json env block.
# The only required value is API_BASE_URL.
# -----------------------------------------------------------------

# Logging
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_PRETTY_PRINT=true

# Environment
NODE_ENV=development

# API endpoint (required)
API_BASE_URL=https://api-project-brain-dev.h2bis.com