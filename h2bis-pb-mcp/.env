# MongoDB connection is managed by h2bis-pb-api, not directly by MCP.
# MCP communicates exclusively through the REST API (API_BASE_URL).
# DB_NAME is documented in .github/copilot-instructions.md for AI agent context.

# Server
SERVER_NAME=h2bis-pb-mcp
SERVER_VERSION=1.0.0

# Logging
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_PRETTY_PRINT=true

# Environment
NODE_ENV=production

# agent authentication key (for MCP agents) similar to JWT
API_BASE_URL=http://localhost:4000
API_KEY=h2b_agent_cHKJrw7BvcGo5-apCiUeI-w7w_nb3EY3x47fz4IgpOc