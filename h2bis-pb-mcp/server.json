{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.h2bis-dev/h2bis-projectbrain-mcp",
  "description": "MCP server for H2BIS ProjectBrain - connect AI agents (GitHub Copilot, Claude, Cursor) to manage projects, use cases, and capabilities.",
  "repository": {
    "url": "https://github.com/h2bis-dev/h2bis-project-brain-mcp",
    "source": "github"
  },
  "version": "1.1.16",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "h2bis-mcp",
      "version": "1.1.16",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "API_BASE_URL",
          "description": "H2BIS ProjectBrain API base URL",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
