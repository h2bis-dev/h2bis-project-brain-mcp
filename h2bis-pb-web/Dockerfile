# ============================================================
# h2bis-pb-web/Dockerfile
# Build context: ./h2bis-pb-web
#
# Uses Next.js "standalone" output mode (set in next.config.ts).
# The standalone build produces a self-contained server.js that
# can run without a full node_modules directory — much smaller
# final image (~150MB vs ~600MB).
#
# IMPORTANT: NEXT_PUBLIC_* variables are embedded at BUILD time
# by the Next.js compiler, not at runtime. They are passed from
# docker-compose as build args.
# ============================================================

# ---- Stage 1: Builder ----------------------------------------
FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# NEXT_PUBLIC_ vars must be present during "next build" because
# they are inlined into the client-side JS bundle at compile time.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Ensure public/ always exists — it may be absent in repos with no static assets
RUN mkdir -p public

RUN npm run build
# Output: .next/standalone/ + .next/static/ + public/

# ---- Stage 2: Runner -----------------------------------------
# Standalone mode — no node_modules needed in the runner stage
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# standalone/ contains a minimal server.js with only required modules
COPY --from=builder /app/.next/standalone ./
# Static assets (JS/CSS chunks, images) are served from here
COPY --from=builder /app/.next/static ./.next/static
# Public folder (favicon, images, etc.)
COPY --from=builder /app/public ./public

EXPOSE 3000

# server.js is generated by Next.js standalone — it boots the HTTP server
CMD ["node", "server.js"]
