{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.h2bis-dev/h2bis-projectbrain-mcp",
  "title": "H2BIS ProjectBrain MCP",
  "description": "Connect AI agents to H2BIS ProjectBrain - manage projects, use cases, and capabilities via MCP.",
  "repository": {
    "url": "https://github.com/h2bis-dev/h2bis-project-brain-mcp",
    "source": "github",
    "subfolder": "h2bis-pb-mcp"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/h2bis-dev/h2bis-project-brain-mcp/main/h2bis-pb-mcp/icon.png",
      "mimeType": "image/png",
      "sizes": ["128x128"]
    }
  ],
  "version": "1.1.18",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "h2bis-mcp",
      "version": "1.1.18",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "API_BASE_URL",
          "description": "H2BIS ProjectBrain API base URL",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
