{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API (Backend)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/h2bis-pb-api",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/h2bis-pb-api/dist/**/*.js"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/h2bis-pb-api/**",
                "!**/node_modules/**"
            ]
        },
        {
            "name": "Debug Web (Frontend)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/h2bis-pb-web",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "serverReadyAction": {
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "name": "Debug MCP (Backend)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/h2bis-pb-mcp",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "serverReadyAction": {
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "name": "Debug AI (Backend)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/h2bis-pb-ai",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "serverReadyAction": {
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        }

    ],
    "compounds": [
        {
            "name": "Debug Full Stack",
            "configurations": [
                "Debug API (Backend)",
                "Debug Web (Frontend)",
                "Debug MCP (Backend)"
            ],
            "presentation": {
                "hidden": false,
                "group": "Full Stack",
                "order": 1
            },
            "stopAll": true
        }
    ]
}