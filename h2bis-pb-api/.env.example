# H2BIS ProjectBrain API - Environment Configuration

# Database
MONGODB_URI=mongodb://localhost:27017/h2bis-pb
NODE_ENV=development
PORT=3000

# JWT Authentication
# IMPORTANT: Change these secrets in production! Use cryptographically strong random strings.
# You can generate secure secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-access-key-change-me-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me-in-production

# Note: Token expiration times are configured in jwt.service.ts
# Access Token: 1 hour (3600 seconds)
# Refresh Token: 7 days (604800 seconds)
