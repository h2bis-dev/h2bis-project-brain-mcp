{
  "name": "h2bis-projectbrain",
  "displayName": "H2BIS ProjectBrain",
  "description": "Connect AI agents (GitHub Copilot, Claude, Cursor) to the H2BIS ProjectBrain API — manage projects, use cases, and capabilities via MCP.",
  "version": "1.1.2",
  "publisher": "H2BISProjectBrain",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Chat",
    "AI"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "project-management",
    "copilot",
    "use-cases",
    "sdlc"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "icon.ico",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "h2bis-pb-mcp",
        "label": "H2BIS ProjectBrain"
      }
    ],
    "commands": [
      {
        "command": "h2bis-projectbrain.startServer",
        "title": "H2BIS ProjectBrain: Start MCP Server"
      },
      {
        "command": "h2bis-projectbrain.stopServer",
        "title": "H2BIS ProjectBrain: Stop MCP Server"
      }
    ],
    "configuration": {
      "title": "H2BIS ProjectBrain",
      "properties": {
        "h2bis.apiBaseUrl": {
          "type": "string",
          "default": "https://api-project-brain-dev.h2bis.com",
          "description": "H2BIS ProjectBrain API base URL. Change this if you use a self-hosted instance."
        },
        "h2bis.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP server when VS Code opens."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "copy-server": "cd ../h2bis-pb-mcp && npm run build && xcopy /E /Y /I dist ..\\\"H2BIS ProjectBrain\"\\server\\dist",
    "package": "npm run copy-server && vsce package",
    "publish": "npm run copy-server && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
