{
  "name": "h2bis-projectbrain",
  "displayName": "H2BIS ProjectBrain",
  "description": "Connect AI agents (GitHub Copilot, Claude, Cursor) to the H2BIS ProjectBrain API — manage projects, use cases, and capabilities via MCP.",
  "version": "1.0.0",
  "publisher": "H2BISProjectBrain",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "ai",
    "project-management",
    "copilot",
    "use-cases",
    "sdlc"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "icon.ico",
  "contributes": {
    "mcpServers": {
      "h2bis-pb-mcp": {
        "type": "stdio",
        "command": "node",
        "args": [
          "${extensionPath}/server/dist/index.js"
        ],
        "env": {
          "API_BASE_URL": "${config:h2bis.apiBaseUrl}"
        }
      }
    },
    "configuration": {
      "title": "H2BIS ProjectBrain",
      "properties": {
        "h2bis.apiBaseUrl": {
          "type": "string",
          "default": "https://api-project-brain-dev.h2bis.com",
          "description": "H2BIS ProjectBrain API base URL. Change this if you use a self-hosted instance."
        }
      }
    }
  },
  "scripts": {
    "build:server": "node scripts/build.mjs",
    "build:ext": "tsc -p tsconfig.json",
    "build": "npm run build:server && npm run build:ext",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}